import CoreData
import CoreDataEvolution
import Foundation

@objc(Item)
@PersistentModel(
  generateInit: true,
  relationshipSetterPolicy: .plain,
  relationshipCountPolicy: .none
)
final class Item: NSManagedObject {
  @Attribute(persistentName: "timestamp")
  var date: Date?

  var title: String = ""

  @Ignore
  var transientCache: [String: Int] = [:]

  @Inverse("items")
  var tags: Set<Tag>

  @Inverse("orderedItems")
  var orderedTags: [Tag]
  var category: Category?
}
